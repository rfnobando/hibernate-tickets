<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 5.0//EN"
"http://www.hibernate.org/dtd/hibernate-mapping">

<hibernate-mapping package="model">
    <class name="model.ProfilePicture" table="profile_pictures">
        <id name="id" column="id">
            <generator class="identity"/>
        </id>
        <property name="fileName" column="file_name" type="string" unique="true"/>
        <many-to-one name="user" column="user_id" class="model.User" unique="true" not-null="true"/>
    </class>
</hibernate-mapping>