<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="model.AttachedPhoto" table="attached_pictures">
        <id column="id" name="id">
            <generator class="identity"/>
        </id>

        <property column="file_name" name="name" type="string"/>

        <many-to-one name="ticketMessage" column="ticket_message_id" class="model.TicketMessage" not-null="true"/>
    </class>
</hibernate-mapping>
