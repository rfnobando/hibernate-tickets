<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package= "model">

    <class name="Ticket" table="tickets">
        <id column="id" name="id">
            <generator class="identity"/>
        </id>

        <property column="title" name="title" type="string"/>
        <property column="created_at" name="creationDate" type="local-date"/>
        <property column="updated_at" name="updateDate" type="local-date"/>

        <many-to-one name="client" column="customer_id" class="model.Client" not-null="true"/>
        <many-to-one name="ticketCategory" column="ticket_category_id" class="model.TicketCategory" not-null="true"/>
        <many-to-one name="status" column="status_id" class="model.Status" not-null="true"/>

        <set name="employees" table="employees_tickets" inverse="true" lazy="true" fetch="select">
            <key column="ticket_id"/>
            <many-to-many column="employee_id" class="model.Employee"/>
        </set>

        <set name="messages" table="ticket_messages" inverse="true" lazy="true" fetch="select">
            <key column="ticket_id" not-null="true"/>
            <one-to-many class="model.TicketMessage"/>
        </set>
        
    </class>

</hibernate-mapping>
