<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 5.0//EN"
"http://www.hibernate.org/dtd/hibernate-mapping">
<hibernate-mapping package="model">
    <class name="model.AttachedPicture" table="attached_pictures">
        <id column="id" name="id">
            <generator class="identity"/>
        </id>

	<property column="file_name" name="name" type="string" unique="true"/>

        <many-to-one name="ticketMessage" column="ticket_message_id" class="model.TicketMessage" not-null="true"/>
    </class>
</hibernate-mapping>