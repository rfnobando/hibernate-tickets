<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 5.0//EN"
"http://www.hibernate.org/dtd/hibernate-mapping">
<hibernate-mapping package="model">
    <class name="model.Ticket" table="tickets">
        <id name="id" column="id">
            <generator class="identity"/>
        </id>
        <property name="title" column="title" type="string"/>
        <property name="createdAt" column="created_at" type="timestamp"/>
        <property name="updatedAt" column="updated_at" type="timestamp"/>
        <many-to-one name="customer" column="customer_id" class="model.Customer" not-null="true"/>
        <many-to-one name="ticketCategory" column="ticket_category_id" class="model.TicketCategory" not-null="true"/>
        <many-to-one name="status" column="status_id" class="model.Status" not-null="true"/>
        <set name="employees" table="employees_tickets" lazy="true" fetch="select">
            <key column="ticket_id" not-null="true"/>
            <many-to-many column="employee_id" class="model.Employee"/>
        </set>
        <set name="messages" table="ticket_messages" inverse="true" lazy="true" fetch="select" cascade="save-update">
            <key column="ticket_id" not-null="true"/>
            <one-to-many class="model.TicketMessage"/>
        </set>
    </class>
</hibernate-mapping>