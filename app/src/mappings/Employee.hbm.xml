<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="model">

    <joined-subclass name="model.Employee" table="employees">
        <key column="user_id" />

        <set name="managedTickets" table="employees_tickets" lazy="true" cascade="all">
            <key column="employee_id"/>
            <many-to-many class="model.Ticket" column="ticket_id"/>
        </set>

    </joined-subclass>

</hibernate-mapping>