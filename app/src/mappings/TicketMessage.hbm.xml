<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 5.0//EN"
"http://www.hibernate.org/dtd/hibernate-mapping">

<hibernate-mapping package="model">
    <class name="model.TicketMessage" table="ticket_messages">
        <id name="id" column="id">
            <generator class="identity"/>
        </id>
        <property name="body" column="body" type="string"/>
        <property name="createdAt" column="created_at" type="timestamp"/>
        <many-to-one name="user" column="user_id" class="model.User" not-null="true"/>
        <set name="attachedPictures" table="attached_pictures" inverse="true" lazy="true" fetch="select">
            <key column="ticket_message_id" not-null="true"/>
            <one-to-many class="model.AttachedPicture"/>
        </set>
        <many-to-one name="ticket" column="ticket_id" class="model.Ticket" not-null="true"/>
        <!-- This links each message to a specific ticket (foreign key in DB); required for proper relationship mapping -->
    </class>
</hibernate-mapping>
